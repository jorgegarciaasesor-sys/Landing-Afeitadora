# Shopify Admin API — generado vía OAuth con la Custom App "VERCEL 2"
SHOPIFY_STORE_DOMAIN=tutienda.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01

# Meta (Pixel + Conversions API). Pegar valores reales en .env.local
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_TOKEN=

# TikTok (Pixel + Events API)
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=

# URL pública del sitio (Vercel la inyecta en producción si la dejás vacía)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
